# .env.example - Environment Variables Template
# ===============================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env"
# 2. Replace the placeholder values with your actual values
# 3. NEVER commit your .env file to Git (it contains secrets!)

# Your Groq API Key
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# (Optional) Which AI model to use
# Options: llama-3.1-8b-instant (faster), llama-3.3-70b-versatile (better quality)
# Default: llama-3.3-70b-versatile
MODEL_NAME=llama-3.3-70b-versatile

# (Optional) AI creativity level (0.0 = factual, 1.0 = creative)
# Default: 0.7
TEMPERATURE=0.7
